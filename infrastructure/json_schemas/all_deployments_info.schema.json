{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "all_deployments_info.schema.json",
  "type": "object",
  "required": [
    "commit_sha",
    "commit_url",
    "workflow_url",
    "started_at",
    "completed_at",
    "hpc_targets"
  ],
  "additionalProperties": false,
  "properties": {
    "commit_sha": { "type": "string" },
    "commit_url": { "type": "string" },
    "workflow_url": { "type": "string" },
    "started_at": { "type": "string" },
    "completed_at": { "type": "string" },
    "hpc_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "hpc_target_deployment_info.schema.json"
      }
    }
  }
}